{
  "manifest_version": 3,
  "name": "Mutable Butterfly",
  "version": "1.1.0",
  "description": "Convert images locally using the Canvas API. Encode messages with the steganography tool",
  "icons": {
    "16": "butterfly_icon_16x16.png",
    "48": "butterfly_icon_48x48.png",
    "128": "butterfly_icon_128x128.png"
  },
    "action":{
      "default_popup": "popup.html",
      "default_icon": {
        "128": "butterfly_icon_128x128.png"
      }
    },
  "permissions": ["tabs", "downloads"]
}